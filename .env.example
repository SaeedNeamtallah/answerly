# RAGMind Configuration Template
# Copy this file to .env and modify the values

# ========================================
# Environment
# ========================================
# Set to "production" to enforce strict secret validation.
ENVIRONMENT=development
CONTEXT_TOKEN_BUDGET=6000
SECURITY_SIMULATION_DESTRUCTIVE_ENABLED=false
TELEGRAM_OUTBOX_POLL_INTERVAL_SECONDS=2
TELEGRAM_OUTBOX_MAX_DELIVERY_ATTEMPTS=3

# ========================================
# Database Configuration (Docker)
# ========================================
# Default Docker database URL (no changes needed if using docker-compose)
DATABASE_URL=postgresql+asyncpg://ragmind:ragmind123@localhost:5435/ragmind

# ========================================
# LLM Provider Configuration
# ========================================
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LITE_MODEL=gemini-2.5-flash-lite
GEMINI_EMBED_MODEL=models/gemini-embedding-001
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_GEMINI_2_FLASH_MODEL=google/gemini-2.0-flash-001
OPENROUTER_FREE_MODEL=openrouter/free
OPENROUTER_GEMMA_4_26B_A4B_MODEL=google/gemma-4-26b-a4b-it
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_LLAMA_3_3_70B_VERSATILE_MODEL=llama-3.3-70b-versatile
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_LLAMA_3_1_8B_MODEL=llama-3.1-8b
EMBEDDING_PROVIDER=gemini
COHERE_API_KEY=your_cohere_api_key_here
COHERE_EMBED_MODEL=embed-multilingual-v3.0

# ========================================
# Vector Database Configuration
# ========================================
# Options: pgvector, qdrant
VECTOR_DB_PROVIDER=pgvector

# Qdrant settings (Docker container runs on port 6333)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ========================================
# Storage Configuration
# ========================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ========================================
# Text Chunking Configuration
# ========================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ========================================
# API Configuration
# ========================================
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE=RAGMind API
API_VERSION=1.0.0

# ========================================
# Product Role Bootstrap
# ========================================
# Username that should be promoted to platform_owner after login.
PLATFORM_OWNER_USERNAME=

# ========================================
# Legacy Telegram Bot Configuration (Optional, Deprecated)
# ========================================
# Deprecated demo bot. Production support uses /bot-integrations.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your Telegram user ID (get from @userinfobot)
TELEGRAM_ADMIN_ID=your_telegram_admin_id_here

# ========================================
# Database-backed Telegram SaaS Configuration
# ========================================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BOT_TOKEN_ENCRYPTION_KEY=
# Public HTTPS backend base URL used to register Telegram webhooks.
PUBLIC_WEBHOOK_BASE_URL=
TELEGRAM_WEBHOOK_REQUESTS_PER_MINUTE=30
TELEGRAM_WEBHOOK_MAX_IN_FLIGHT=2
TELEGRAM_RAW_PAYLOAD_RETENTION_DAYS=30

# Require auth for config-changing mutation endpoints by default.
SECURITY_REQUIRE_AUTH_FOR_MUTATIONS=true

# ========================================
# CORS Configuration
# ========================================
CORS_ORIGINS=["http://localhost:3001", "http://localhost:3000", "http://localhost:8080", "http://localhost:8000"]

# ========================================
# Logging Configuration
# ========================================
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
