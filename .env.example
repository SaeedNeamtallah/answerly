# RAGMind Configuration Template
# Copy this file to .env and modify the values

# ========================================
# Database Configuration (Docker)
# ========================================
# Default Docker database URL (no changes needed if using docker-compose)
DATABASE_URL=postgresql+asyncpg://ragmind:ragmind123@localhost:5435/ragmind

# ========================================
# LLM Provider Configuration
# ========================================
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=
LLM_PROVIDER=gemini
GEMINI_MODEL=gemma-4-26b-a4b-it
GEMINI_LITE_MODEL=gemini-2.5-flash-lite

# ========================================
# Embedding Configuration
# ========================================
# Options: gemini, cohere, voyage, huggingface
EMBEDDING_PROVIDER=cohere
GEMINI_EMBED_MODEL=models/gemini-embedding-001

# Cohere (https://cohere.com/)
COHERE_API_KEY=YOUR_COHERE_API_KEY_HERE
COHERE_EMBED_MODEL=embed-multilingual-v3.0
COHERE_MAX_BATCH_TOKENS=50000
COHERE_MAX_RETRIES=12
COHERE_BASE_RETRY_DELAY=2.0

# Voyage AI (https://www.voyageai.com/)
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-3-large
VOYAGE_OUTPUT_DIMENSION=1024

# HuggingFace local embedding
HF_EMBED_MODEL=BAAI/bge-m3
# Embedding performance
EMBEDDING_BATCH_SIZE=96
EMBEDDING_CONCURRENCY=4

# ========================================
# OpenRouter Configuration
# ========================================
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_GEMINI_2_FLASH_MODEL=google/gemini-2.0-flash-001
OPENROUTER_FREE_MODEL=openrouter/free
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=

# ========================================
# Groq Configuration
# ========================================
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_LLAMA_3_3_70B_VERSATILE_MODEL=llama-3.3-70b-versatile
GROQ_GPT_OSS_120B_MODEL=gpt-oss-120b

# ========================================
# Cerebras Configuration
# ========================================
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_LLAMA_3_3_70B_MODEL=llama-3.3-70b
CEREBRAS_LLAMA_3_1_8B_MODEL=llama-3.1-8b
CEREBRAS_GPT_OSS_120B_MODEL=gpt-oss-120b

# ========================================
# Vector Database Configuration
# ========================================
# Options: pgvector, qdrant
VECTOR_DB_PROVIDER=pgvector

# Qdrant settings (Docker container runs on port 6333)
QDRANT_URL=http://localhost:6381
QDRANT_API_KEY=
QDRANT_UPSERT_BATCH_SIZE=256

# ========================================
# Storage Configuration
# ========================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ========================================
# Text Chunking Configuration
# ========================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
PARENT_CHUNK_SIZE=3000
PARENT_CHUNK_OVERLAP=600
# Options: parent_child, simple
CHUNK_STRATEGY=parent_child

# ========================================
# Retrieval Configuration
# ========================================
RETRIEVAL_TOP_K=5
RETRIEVAL_TOP_K_MAX=20
RETRIEVAL_CANDIDATE_K=20
RETRIEVAL_HYBRID_ENABLED=false
RETRIEVAL_HYBRID_ALPHA=0.7
RETRIEVAL_RERANK_ENABLED=false
RETRIEVAL_RERANK_TOP_K=10
QUERY_REWRITE_ENABLED=false

# ========================================
# API Configuration
# ========================================
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE=RAGMind API
API_VERSION=1.0.0

# ========================================
# Security Configuration
# ========================================
# Set a long random secret in production.
AUTH_JWT_SECRET_KEY=change-me-in-env
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Admin login used by /auth/login.
AUTH_ADMIN_USERNAME=
AUTH_ADMIN_PASSWORD=
# Optional: preferred over plain password. Format:
# pbkdf2_sha256$<iterations>$<salt_base64>$<hash_base64>
AUTH_ADMIN_PASSWORD_HASH=

# Keep false during migration to avoid breaking existing write clients.
SECURITY_REQUIRE_AUTH_FOR_MUTATIONS=true

# Default temporary suspension duration (minutes) for security-triggered account suspensions.
SECURITY_USER_SUSPENSION_DEFAULT_MINUTES=30

# Rate limiting
SECURITY_RATE_LIMIT_ENABLED=true
SECURITY_RATE_LIMIT_GLOBAL_ENABLED=false
# Optional global fallback (used only when SECURITY_RATE_LIMIT_GLOBAL_ENABLED=true)
SECURITY_RATE_LIMIT_REQUESTS_PER_WINDOW=300
SECURITY_RATE_LIMIT_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_EXEMPT_PATHS=/health,/docs,/openapi.json,/redoc

# Chat anti-spam (POST /projects/{id}/query and /query/stream)
SECURITY_RATE_LIMIT_CHAT_REQUESTS_PER_WINDOW=30
SECURITY_RATE_LIMIT_CHAT_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_CHAT_MAX_IN_FLIGHT=2

# Upload anti-burst (POST /projects/{id}/documents)
SECURITY_RATE_LIMIT_UPLOAD_REQUESTS_PER_WINDOW=8
SECURITY_RATE_LIMIT_UPLOAD_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_UPLOAD_MAX_IN_FLIGHT=2

# Project creation anti-abuse (POST /projects/)
SECURITY_RATE_LIMIT_PROJECT_CREATE_REQUESTS_PER_WINDOW=10
SECURITY_RATE_LIMIT_PROJECT_CREATE_WINDOW_SECONDS=300
SECURITY_RATE_LIMIT_PROJECT_CREATE_MAX_IN_FLIGHT=2

# Login anti-bruteforce (POST /auth/login)
SECURITY_RATE_LIMIT_LOGIN_REQUESTS_PER_WINDOW=6
SECURITY_RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_LOGIN_MAX_IN_FLIGHT=2

# Login brute-force guard
SECURITY_LOGIN_BRUTEFORCE_ENABLED=true
SECURITY_LOGIN_BRUTEFORCE_THRESHOLD=4
SECURITY_LOGIN_BRUTEFORCE_WINDOW_SECONDS=60
SECURITY_LOGIN_BRUTEFORCE_BLOCK_SECONDS=60
# Demo notes:
# - At threshold: temporary login lock is triggered (retry after 60s)
# - Progressive failed-login delay in backend route:
#   attempt 1 -> 0s, attempt 2 -> 1s, attempt 3 -> 3s, attempt 4 -> lock
# - Account suspension may apply after lock threshold when failures continue.
# - At >= 2x threshold: account is blocked
# Keep values low in test environments to trigger behavior quickly.

# Upload hardening
SECURITY_UPLOAD_VALIDATE_MAGIC=true
SECURITY_UPLOAD_MAX_SCAN_BYTES=8192

# ========================================
# Telegram Bot Configuration (Optional)
# ========================================
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your Telegram user ID (get from @userinfobot)
TELEGRAM_ADMIN_ID=
# Backend API base URL for the bot to connect to
API_BASE_URL=http://localhost:8000
# Optional bot identity for authenticated query calls.
# If unset, bot falls back to AUTH_ADMIN_USERNAME / AUTH_ADMIN_PASSWORD.
BOT_API_USERNAME=
BOT_API_PASSWORD=
# Optional override for bot active project id.
# If unset, bot uses active_project_id from bot_config.json.
BOT_ACTIVE_PROJECT_ID=

# ========================================
# CORS Configuration
# ========================================
CORS_ORIGINS=["http://localhost", "http://127.0.0.1", "http://localhost:3000", "http://localhost:8080", "http://localhost:8000", "http://127.0.0.1:8000"]

# ========================================
# Logging Configuration
# ========================================
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ========================================
# Celery Configuration
# ========================================
# RabbitMQ broker (matches docker/env/.env.rabbitmq credentials)
CELERY_BROKER_URL=amqp://minirag_user:minirag_rabbitmq_2222@localhost:5729/minirag_vhost
# Redis result backend (matches docker/env/.env.redis credentials)
CELERY_RESULT_BACKEND=redis://:minirag_redis_2222@localhost:6383/0
CELERY_TASK_SERIALIZER=json
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_ACKS_LATE=true
CELERY_WORKER_CONCURRENCY=2
CELERY_FLOWER_PASSWORD="minirag_flower_2222"